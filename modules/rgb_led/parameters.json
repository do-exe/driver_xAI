{
  "module_id": "rgb_led",
  "interface": "gpio",
  "protocol": null,
  "pins": {
    "red": null,
    "green": null,
    "blue": null
  },
  "options": {
    "common_type": {
      "default": "common_cathode",
      "allowed": ["common_cathode", "common_anode"]
