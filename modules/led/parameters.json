{
  "module_id": "led",
  "interface": "gpio",
  "protocol": null,
  "pins": {
    "channels": {}
  },
  "options": {
    "mode": {
      "default": "pwm",
      "allowed": ["pwm", "digital"]
    },
    "active_high": {
      "default": true,
      "allowed": [true, false]
    },
    "common_type": {
      "default": "common_cathode",
      "allowed": ["common_cathode", "common_anode", null]
    },
    "pwm_frequency_hz": {
      "default": 1000,
      "allowed_range": [100, 5000]
    },
    "max_value": {
      "default": 255,
      "allowed_range": [1, 65535]
    }
  },
  "custom": {}
}
