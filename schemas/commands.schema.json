{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/do-exe/driver_xAI/schemas/commands.schema.json",
  "title": "Driver xAI module commands",
  "type": "object",
  "required": ["commands"],
  "properties": {
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "inputs", "output"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "description": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9_]+$"
            }
          },
          "output": {
            "type": "string"
          },
          "driver_method": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_]+$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
