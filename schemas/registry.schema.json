{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/do-exe/driver_xAI/schemas/registry.schema.json",
  "title": "Driver xAI registry",
  "type": "object",
  "required": ["type", "id", "name", "modules"],
  "properties": {
    "type": {
      "enum": ["protocol", "interface"]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
